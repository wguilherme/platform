# ============================================================
# Claudin — Environment Variables
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Token do bot Discord (obtido no Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Webhook URL do canal onde o agente vai postar status/alertas
# Criado em: Canal Discord → Editar Canal → Integrações → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ID do canal Discord onde o agente vai receber comandos
DISCORD_CHANNEL_ID=your_channel_id_here

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Projeto ───────────────────────────────────────────────────
# Caminho absoluto para o projeto no servidor
PROJECT_PATH=/home/pi/project

# Nome da máquina para identificação nas mensagens
MACHINE_NAME=raspberry-pi-4b

# ── Health Check ──────────────────────────────────────────────
# Intervalo do heartbeat em segundos (padrão: 300 = 5 minutos)
HEARTBEAT_INTERVAL=300

# URL de um serviço externo dead-man's switch (opcional)
# Opções: https://healthchecks.io, https://betteruptime.com, https://uptime.betterstack.com
# Quando configurado, o heartbeat faz ping nessa URL periodicamente
# Se o ping parar (máquina cair), o serviço envia alerta externo
HEALTHCHECK_PING_URL=https://hc-ping.com/YOUR_UUID_HERE

# ── Trello (opcional — fallback para backlog.md se não configurado) ───────────
# Obter API Key e Token: https://trello.com/power-ups/admin → New Power-Up → API Key
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_oauth_token
# IDs das listas (colunas) do board — clique na lista → compartilhar → copiar link → ID no URL
TRELLO_BACKLOG_LIST_ID=list_id_backlog
TRELLO_IN_PROGRESS_LIST_ID=list_id_in_progress
TRELLO_DONE_LIST_ID=list_id_done
TRELLO_BLOCKED_LIST_ID=list_id_blocked

# ── Task Provider ─────────────────────────────────────────────────────────────
# Qual implementação de backlog usar:
#   markdown  — lê/escreve claudin/tasks/backlog.md  (padrão, sem dependências)
#   trello    — Trello REST API  (requer TRELLO_* vars abaixo)
#   mcp-jira  — agente usa JIRA via MCP tools  (requer JIRA_* vars abaixo)
# Pode ser sobrescrito via: make start-loop TASK_PROVIDER=mcp-jira
TASK_PROVIDER=markdown

# ── JIRA (quando TASK_PROVIDER=jira ou mcp-jira) ─────────────────────────────
# Base URL do seu Atlassian Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
# E-mail da conta Atlassian
JIRA_EMAIL=you@example.com
# API Token — gere em: id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here
# Chave do projeto JIRA (ex: "DEV", "PROJ", "ORION")
JIRA_PROJECT=DEV

# ── JIRA Provider híbrido (TASK_PROVIDER=jira) ────────────────────────────────
# Colunas que o loop vai buscar via REST (vírgula separada)
# Use os nomes exatos dos status do seu board
JIRA_TODO_STATUSES=To Do
# Status de transição para cada estado (use nomes exatos do workflow)
JIRA_IN_PROGRESS_STATUS=In Progress
JIRA_DONE_STATUS=Done
JIRA_BLOCKED_STATUS=Blocked

# ── Agent Loop (agent-loop.ts) ─────────────────────────────────────────────────
# Número máximo de turnos por tarefa antes de auto-resumo
MAX_TURNS_PER_TASK=40
# Pausa entre ciclos em milissegundos
SLEEP_BETWEEN_CYCLES_MS=10000
# Número de tentativas antes de marcar tarefa como bloqueada
RETRY_LIMIT=3
# Intervalo do heartbeat em milissegundos (padrão: 5 minutos)
HEARTBEAT_INTERVAL_MS=300000

# ── Git ───────────────────────────────────────────────────────
GIT_USER_NAME=claudin-bot
GIT_USER_EMAIL=claudin@orion.dev

# ── SSH ───────────────────────────────────────────────────────
# Caminho absoluto para a chave SSH usada para push no Git
# O agente carrega esta chave automaticamente ao iniciar
# Gere com: ssh-keygen -t ed25519 -C "claudin@orion.dev" -f ~/.ssh/claudin_ed25519
# Adicione a chave pública ao GitHub: Settings → SSH Keys
SSH_KEY_PATH=/home/pi/.ssh/claudin_ed25519

# Caminho para o diretório .ssh (usado se precisar verificar/reconfigurar)
SSH_DIR=/home/pi/.ssh

# Known hosts — adicione o GitHub automaticamente com:
# ssh-keyscan github.com >> ~/.ssh/known_hosts
